{
  "name": "cloud-bai-core",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm run \"/dev:(app|server)/\"",
    "dev:app": "pnpm --filter @cloud-bai/app dev",
    "dev:server": "pnpm --filter @cloud-bai/server dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
