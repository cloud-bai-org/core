# Google OAuth
NUXT_PUBLIC_GOOGLE_CLIENT_ID=

# LINE Login
NUXT_PUBLIC_LINE_CHANNEL_ID=

# Auth redirect base URL (e.g. http://localhost:3000)
NUXT_PUBLIC_AUTH_REDIRECT_BASE=http://localhost:3000

# Supabase（前端透過 NUXT_PUBLIC_ 前綴注入 runtime config）
NUXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase（後端使用）
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
